@unpublished{CTD5G,
	title = {Control Traffic Dataset and Generation Framework for 5G Networks},
	url = {https://laas.hal.science/hal-05530523},
	doi = {10.5281/zenodo.15853959},
	abstract = {The changes introduced by 5G significantly expand the attack surface of mobile networks and bring new vulnerabilities, particularly within the control traffic. To address these risks, numerous studies have proposed anomaly detection models. However, the development and evaluation of such solutions are hindered by the lack of publicly available control traffic datasets. As a result, current anomaly detection tools must generate their own data, which hinders the reproducibility of results and complicates comparisons between different approaches. To address this gap, we introduce a set of tools and a methodology designed to generate diversified and realistic datasets for 5G anomaly detection. Our tools are open and collaborative by design, enabling progressive extension to incorporate a wider variety of plausible messages and interactions. As part of this effort to unite the 5G anomaly detection community, we also provide an initial version of a dataset that is diverse, reproducible, and designed to co-evolve through community contributions.},
	author = {Hoger, Thomas and Owezarski, Philippe and Durand-Nauze, Guilhem},
	urldate = {2026-03-20},
	date = {2026-02},
	doi = {10.5281/zenodo.15853959},
	keywords = {5G dataset framework, anomaly detection, multi-surface 5G attacks},
	file = {HAL Snapshot:C\:\\Users\\thoger\\Zotero\\storage\\AD8QP4WW\\hal-05530523.html:text/html},
}

