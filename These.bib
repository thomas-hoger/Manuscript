@article{5GCGuard,
	title = {Deep {Learning} {Based} {Proactive} {Anomaly} {Detection} for {5G} {Core} {Control} {Plane} {Network} {Function} {Interactions}},
	issn = {2332-7731},
	url = {https://ieeexplore.ieee.org/abstract/document/10877893},
	doi = {10.1109/TCCN.2025.3539660},
	abstract = {The Service-Based Architecture (SBA) introduced by 3GPP allows the control plane of 5G Core Network (CN) to function through a set of interconnected Network Functions (NFs), which offers significant benefits such as improved scalability, simplified operations, and efficient resource utilization. However, such a new transformation could also make critical NFs in 5G CN become more susceptible to attacks due to both internal vulnerabilities within the software-implemented NFs or the expanded interfaces brought by the SBA. Existing studies targeting 5G network security pay little attention to the detection of abnormal behaviors from control plane NFs. Therefore, in this paper, we propose 5GCGuard, an anomaly detection scheme aiming at identifying abnormal NF interactions in 5G CN. It employs a deep learning-based sequence model to learn normal interaction patterns and detects anomalies based on deviations from the learned pattern. Special designs including attention mechanism, multi-task learning, probabilistic labeling and automatic threshold decision are made to enhance its detection capabilities. We establish a cloud-native 5G testbed to evaluate the effectiveness of 5GCGuard. Extensive evaluation results show its superiority over comparison schemes. Case studies also demonstrate its ability to proactively detect various NF interaction anomalies, enabling swift action to block attacks and prevent further damage.},
	urldate = {2025-05-28},
	journal = {IEEE Transactions on Cognitive Communications and Networking},
	author = {Tan, Yawen and Liu, Jiajia and Li, Yuanhao and Wang, Jiadai},
	year = {2025},
	keywords = {3GPP, 5G core network, 5G mobile communication, anomaly detection, Anomaly detection, Data models, Labeling, NF interaction anomalies, Noise measurement, Privacy, Probabilistic logic, Security, sequence model, Telecommunication traffic},
	pages = {1--1},
	file = {Full Text PDF:C\:\\Users\\thoger\\Zotero\\storage\\4AFZG7HG\\Tan et al. - 2025 - Deep Learning Based Proactive Anomaly Detection fo.pdf:application/pdf},
}

